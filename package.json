    "Data",
    "Cotonou",
    "Porto-Novo",
    "Parakou",
    "Djougou",
    "Bohicon",
    "Kandi",
    "Abomey"
  ],
  "maintainers": [
    {
      "name": "Justin Y. Dah-kenangnon",
      "email": "dah.kenangnon@gmail.com",
      "web": "https://dah-kenangnon.com",
      "twitter": "https://x.com/dahkenangnon",
      "github": "https://github.com/Dahkenangnon"
    }
  ],
  "homepage": "https://location-bj.claviscore.com/",
  "author": {
    "name": "Justin Y. Dah-kenangnon",
    "email": "dah.kenangnon@gmail.com"
  },
  "license": "Apache-2.0",
  "scripts": {
    "dev": "webpack --mode=development --watch",
    "build": "rm -rf dist && tsup && webpack --mode=production && mkdir -p public/dist && cp dist/bundle.js public/dist/bundle.js",
    "test:n": "jest --notify  --detectOpenHandles",
    "test": "jest",
    "coverage": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "files": [
    "dist",
    "readme.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.17.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2",
    "node-notifier": "^10.0.1",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Dahkenangnon/location_data_bj_js.git"

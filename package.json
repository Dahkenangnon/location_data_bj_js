{
  "name": "location_data_bj",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "description": "Benin Republic territory data for web and JS apps",
  "version": "2.1.0",
  "keywords": [
    "Benin",
    "Benin Republic",
    "Territory",
